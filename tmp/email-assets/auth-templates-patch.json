{"mailer_subjects_confirmation":"Confirm your email — Replaceme","mailer_templates_confirmation_content":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"light\" />\n    <meta name=\"supported-color-schemes\" content=\"light\" />\n    <title>Confirm your email</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#f3f6f4;color:#0f172a;-webkit-font-smoothing:antialiased;\">\n    <div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\">\n      Verify your Replaceme email when you’re ready.\n    </div>\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f3f6f4;padding:40px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;\">\n            <tr>\n              <td style=\"padding:0 4px 24px 4px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"vertical-align:middle;padding-right:10px;\">\n                      <img src=\"https://dsbfudkacjrpnilqmiuy.supabase.co/storage/v1/object/public/brand-assets/email/logo.png\" width=\"40\" height=\"40\" alt=\"Replaceme\" style=\"display:block;border:0;border-radius:10px;max-width:100%;height:auto;\" />\n                    </td>\n                    <td style=\"vertical-align:middle;\">\n                      <div style=\"font-weight:800;font-size:20px;letter-spacing:-0.03em;color:#0a4a29;line-height:1;\">\n                        Replaceme\n                      </div>\n                      <div style=\"font-size:12px;color:#64748b;margin-top:4px;font-weight:500;\">\n                        Filipino remote talent, hired directly\n                      </div>\n                    </td>\n                  </tr>\n                </table>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"background:#ffffff;border:1px solid rgba(148,163,184,0.35);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(15,23,42,0.04);\">\n                <div style=\"height:4px;background:linear-gradient(90deg, #0a4a29 0%, #006e2f 100%);\"></div>\n                <div style=\"padding:28px 24px 26px 24px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                  <h1 style=\"margin:0 0 14px 0;font-size:20px;line-height:1.35;color:#0f172a;letter-spacing:-0.03em;font-weight:800;\">\n                    Confirm your email\n                  </h1>\n                  <div style=\"font-size:15px;line-height:1.65;color:#334155;\">\n                    \n    <p style=\"margin:0 0 14px 0;\">Welcome to <strong>Replaceme</strong> — the direct marketplace for Filipino remote talent.</p>\n    <p style=\"margin:0 0 18px 0;\">Confirm your email to finish verifying your account. You can keep using Replaceme in the meantime.</p>\n    <p style=\"margin:0 0 18px 0;\">\n      <a href=\"{{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=signup&next={{ .RedirectTo }}\" style=\"display:inline-block;background:#006e2f;color:#ffffff;text-decoration:none;padding:12px 20px;border-radius:12px;font-weight:700;font-size:14px;letter-spacing:-0.01em;line-height:1.2;\">Confirm email address</a>\n    </p>\n    <p style=\"margin:0;font-size:13px;color:#64748b;line-height:1.55;\">\n      If the button doesn’t work, paste this link into your browser:<br />\n      <span style=\"word-break:break-all;color:#006e2f;\">{{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=signup&next={{ .RedirectTo }}</span>\n    </p>\n  \n                  </div>\n                </div>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:22px 8px 0 8px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <div style=\"font-size:12px;line-height:1.6;color:#64748b;text-align:center;\">\n                  This link expires for your security. Need help? support@replaceme.ph\n                </div>\n                <div style=\"font-size:11px;line-height:1.5;color:#94a3b8;text-align:center;margin-top:10px;\">\n                  © 2026 Replaceme · <a href=\"https://replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">replaceme.ph</a>\n                  · <a href=\"mailto:support@replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">support@replaceme.ph</a>\n                </div>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>","mailer_subjects_recovery":"Reset your password — Replaceme","mailer_templates_recovery_content":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"light\" />\n    <meta name=\"supported-color-schemes\" content=\"light\" />\n    <title>Reset your password</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#f3f6f4;color:#0f172a;-webkit-font-smoothing:antialiased;\">\n    <div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\">\n      Secure link to choose a new Replaceme password.\n    </div>\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f3f6f4;padding:40px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;\">\n            <tr>\n              <td style=\"padding:0 4px 24px 4px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"vertical-align:middle;padding-right:10px;\">\n                      <img src=\"https://dsbfudkacjrpnilqmiuy.supabase.co/storage/v1/object/public/brand-assets/email/logo.png\" width=\"40\" height=\"40\" alt=\"Replaceme\" style=\"display:block;border:0;border-radius:10px;max-width:100%;height:auto;\" />\n                    </td>\n                    <td style=\"vertical-align:middle;\">\n                      <div style=\"font-weight:800;font-size:20px;letter-spacing:-0.03em;color:#0a4a29;line-height:1;\">\n                        Replaceme\n                      </div>\n                      <div style=\"font-size:12px;color:#64748b;margin-top:4px;font-weight:500;\">\n                        Filipino remote talent, hired directly\n                      </div>\n                    </td>\n                  </tr>\n                </table>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"background:#ffffff;border:1px solid rgba(148,163,184,0.35);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(15,23,42,0.04);\">\n                <div style=\"height:4px;background:linear-gradient(90deg, #0a4a29 0%, #006e2f 100%);\"></div>\n                <div style=\"padding:28px 24px 26px 24px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                  <h1 style=\"margin:0 0 14px 0;font-size:20px;line-height:1.35;color:#0f172a;letter-spacing:-0.03em;font-weight:800;\">\n                    Reset your password\n                  </h1>\n                  <div style=\"font-size:15px;line-height:1.65;color:#334155;\">\n                    \n    <p style=\"margin:0 0 14px 0;\">We received a request to reset the password for your <strong>Replaceme</strong> account.</p>\n    <p style=\"margin:0 0 18px 0;\">Choose a new password using the secure link below.</p>\n    <p style=\"margin:0 0 18px 0;\">\n      <a href=\"{{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=recovery&next=/update-password\" style=\"display:inline-block;background:#006e2f;color:#ffffff;text-decoration:none;padding:12px 20px;border-radius:12px;font-weight:700;font-size:14px;letter-spacing:-0.01em;line-height:1.2;\">Reset password</a>\n    </p>\n    <p style=\"margin:0;font-size:13px;color:#64748b;line-height:1.55;\">\n      If you didn’t request a reset, you can safely ignore this email. Your password won’t change.<br /><br />\n      Fallback link:<br />\n      <span style=\"word-break:break-all;color:#006e2f;\">{{ .SiteURL }}/auth/confirm?token_hash={{ .TokenHash }}&type=recovery&next=/update-password</span>\n    </p>\n  \n                  </div>\n                </div>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:22px 8px 0 8px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <div style=\"font-size:12px;line-height:1.6;color:#64748b;text-align:center;\">\n                  This link expires for your security. Need help? support@replaceme.ph\n                </div>\n                <div style=\"font-size:11px;line-height:1.5;color:#94a3b8;text-align:center;margin-top:10px;\">\n                  © 2026 Replaceme · <a href=\"https://replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">replaceme.ph</a>\n                  · <a href=\"mailto:support@replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">support@replaceme.ph</a>\n                </div>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>","mailer_subjects_magic_link":"Your sign-in link — Replaceme","mailer_templates_magic_link_content":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n   