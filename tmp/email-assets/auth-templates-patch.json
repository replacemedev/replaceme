           <tr>\n              <td style=\"background:#ffffff;border:1px solid rgba(148,163,184,0.35);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(15,23,42,0.04);\">\n                <div style=\"height:4px;background:linear-gradient(90deg, #0a4a29 0%, #006e2f 100%);\"></div>\n                <div style=\"padding:28px 24px 26px 24px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                  <h1 style=\"margin:0 0 14px 0;font-size:20px;line-height:1.35;color:#0f172a;letter-spacing:-0.03em;font-weight:800;\">\n                    Your sign-in link\n                  </h1>\n                  <div style=\"font-size:15px;line-height:1.65;color:#334155;\">\n                    <p style=\"margin:0 0 14px 0;\">Use the secure link below to sign in to <strong>Replaceme</strong>.</p><p style=\"margin:0 0 18px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#006e2f;color:#ffffff;text-decoration:none;padding:12px 20px;border-radius:12px;font-weight:700;font-size:14px;\">Sign in</a></p>\n                  </div>\n                </div>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:22px 8px 0 8px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <div style=\"font-size:12px;line-height:1.6;color:#64748b;text-align:center;\">\n                  This link expires for your security. Need help? support@replaceme.ph\n                </div>\n                <div style=\"font-size:11px;line-height:1.5;color:#94a3b8;text-align:center;margin-top:10px;\">\n                  © 2026 Replaceme · <a href=\"https://replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">replaceme.ph</a>\n                  · <a href=\"mailto:support@replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">support@replaceme.ph</a>\n                </div>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>","mailer_subjects_invite":"You've been invited — Replaceme","mailer_templates_invite_content":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"light\" />\n    <meta name=\"supported-color-schemes\" content=\"light\" />\n    <title>You&#039;ve been invited</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#f3f6f4;color:#0f172a;-webkit-font-smoothing:antialiased;\">\n    <div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\">\n      Accept your invitation to join Replaceme.\n    </div>\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f3f6f4;padding:40px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;\">\n            <tr>\n              <td style=\"padding:0 4px 24px 4px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"vertical-align:middle;padding-right:10px;\">\n                      <img src=\"https://dsbfudkacjrpnilqmiuy.supabase.co/storage/v1/object/public/brand-assets/email/logo.png\" width=\"40\" height=\"40\" alt=\"Replaceme\" style=\"display:block;border:0;border-radius:10px;max-width:100%;height:auto;\" />\n                    </td>\n                    <td style=\"vertical-align:middle;\">\n                      <div style=\"font-weight:800;font-size:20px;letter-spacing:-0.03em;color:#0a4a29;line-height:1;\">\n                        Replaceme\n                      </div>\n                      <div style=\"font-size:12px;color:#64748b;margin-top:4px;font-weight:500;\">\n                        Filipino remote talent, hired directly\n                      </div>\n                    </td>\n                  </tr>\n                </table>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"background:#ffffff;border:1px solid rgba(148,163,184,0.35);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(15,23,42,0.04);\">\n                <div style=\"height:4px;background:linear-gradient(90deg, #0a4a29 0%, #006e2f 100%);\"></div>\n                <div style=\"padding:28px 24px 26px 24px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                  <h1 style=\"margin:0 0 14px 0;font-size:20px;line-height:1.35;color:#0f172a;letter-spacing:-0.03em;font-weight:800;\">\n                    You&#039;ve been invited\n                  </h1>\n                  <div style=\"font-size:15px;line-height:1.65;color:#334155;\">\n                    <p style=\"margin:0 0 14px 0;\">You've been invited to create a <strong>Replaceme</strong> account.</p><p style=\"margin:0 0 18px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#006e2f;color:#ffffff;text-decoration:none;padding:12px 20px;border-radius:12px;font-weight:700;font-size:14px;\">Accept invitation</a></p>\n                  </div>\n                </div>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:22px 8px 0 8px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <div style=\"font-size:12px;line-height:1.6;color:#64748b;text-align:center;\">\n                  This link expires for your security. Need help? support@replaceme.ph\n                </div>\n                <div style=\"font-size:11px;line-height:1.5;color:#94a3b8;text-align:center;margin-top:10px;\">\n                  © 2026 Replaceme · <a href=\"https://replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">replaceme.ph</a>\n                  · <a href=\"mailto:support@replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">support@replaceme.ph</a>\n                </div>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>","mailer_subjects_email_change":"Confirm your new email — Replaceme","mailer_templates_email_change_content":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"light\" />\n    <meta name=\"supported-color-schemes\" content=\"light\" />\n    <title>Confirm your new email</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#f3f6f4;color:#0f172a;-webkit-font-smoothing:antialiased;\">\n    <div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\">\n      Confirm the new email address for your Replaceme account.\n    </div>\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f3f6f4;padding:40px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;\">\n            <tr>\n              <td style=\"padding:0 4px 24px 4px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"vertical-align:middle;padding-right:10px;\">\n                      <img src=\"https://dsbfudkacjrpnilqmiuy.supabase.co/storage/v1/object/public/brand-assets/email/logo.png\" width=\"40\" height=\"40\" alt=\"Replaceme\" style=\"display:block;border:0;border-radius:10px;max-width:100%;height:auto;\" />\n                    </td>\n                    <td style=\"vertical-align:middle;\">\n                      <div style=\"font-weight:800;font-size:20px;letter-spacing:-0.03em;color:#0a4a29;line-height:1;\">\n                        Replaceme\n                      </div>\n                      <div style=\"font-size:12px;color:#64748b;margin-top:4px;font-weight:500;\">\n                        Filipino remote talent, hired directly\n                      </div>\n                    </td>\n                  </tr>\n                </table>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"background:#ffffff;border:1px solid rgba(148,163,184,0.35);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(15,23,42,0.04);\">\n                <div style=\"height:4px;background:linear-gradient(90deg, #0a4a29 0%, #006e2f 100%);\"></div>\n                <div style=\"padding:28px 24px 26px 24px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                  <h1 style=\"margin:0 0 14px 0;font-size:20px;line-height:1.35;color:#0f172a;letter-spacing:-0.03em;font-weight:800;\">\n                    Confirm your new email\n                  </h1>\n                  <div style=\"font-size:15px;line-height:1.65;color:#334155;\">\n                    <p style=\"margin:0 0 14px 0;\">Confirm <strong>{{ .NewEmail }}</strong> as your new email address.</p><p style=\"margin:0 0 18px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#006e2f;color:#ffffff;text-decoration:none;padding:12px 20px;border-radius:12px;font-weight:700;font-size:14px;\">Confirm new email</a></p>\n                  </div>\n                </div>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"padding:22px 8px 0 8px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <div style=\"font-size:12px;line-height:1.6;color:#64748b;text-align:center;\">\n                  This link expires for your security. Need help? support@replaceme.ph\n                </div>\n                <div style=\"font-size:11px;line-height:1.5;color:#94a3b8;text-align:center;margin-top:10px;\">\n                  © 2026 Replaceme · <a href=\"https://replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">replaceme.ph</a>\n                  · <a href=\"mailto:support@replaceme.ph\" style=\"color:#006e2f;text-decoration:none;\">support@replaceme.ph</a>\n                </div>\n              </td>\n            </tr>\n          </table>\n        </td>\n      </tr>\n    </table>\n  </body>\n</html>","mailer_subjects_reauthentication":"{{ .Token }} is your Replaceme verification code","mailer_templates_reauthentication_content":"<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <meta name=\"color-scheme\" content=\"light\" />\n    <meta name=\"supported-color-schemes\" content=\"light\" />\n    <title>Your verification code</title>\n  </head>\n  <body style=\"margin:0;padding:0;background:#f3f6f4;color:#0f172a;-webkit-font-smoothing:antialiased;\">\n    <div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;\">\n      Use this code to verify your identity on Replaceme.\n    </div>\n    <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f3f6f4;padding:40px 16px;\">\n      <tr>\n        <td align=\"center\">\n          <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;\">\n            <tr>\n              <td style=\"padding:0 4px 24px 4px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                <table role=\"presentation\" cellpadding=\"0\" cellspacing=\"0\">\n                  <tr>\n                    <td style=\"vertical-align:middle;padding-right:10px;\">\n                      <img src=\"https://dsbfudkacjrpnilqmiuy.supabase.co/storage/v1/object/public/brand-assets/email/logo.png\" width=\"40\" height=\"40\" alt=\"Replaceme\" style=\"display:block;border:0;border-radius:10px;max-width:100%;height:auto;\" />\n                    </td>\n                    <td style=\"vertical-align:middle;\">\n                      <div style=\"font-weight:800;font-size:20px;letter-spacing:-0.03em;color:#0a4a29;line-height:1;\">\n                        Replaceme\n                      </div>\n                      <div style=\"font-size:12px;color:#64748b;margin-top:4px;font-weight:500;\">\n                        Filipino remote talent, hired directly\n                      </div>\n                    </td>\n                  </tr>\n                </table>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"background:#ffffff;border:1px solid rgba(148,163,184,0.35);border-radius:20px;overflow:hidden;box-shadow:0 8px 30px rgba(15,23,42,0.04);\">\n                <div style=\"height:4px;background:linear-gradient(90deg, #0a4a29 0%, #006e2f 100%);\"></div>\n                <div style=\"padding:28px 24px 26px 24px;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;\">\n                  <h1 style=\"margin:0 0 14px 0;font-size:20px;line-height:1.35;color:#0f172a;letter-spacing:-0.03em;font-weight:800;\">\n                    Your verification code\n                  </h1>\n                  <div style=\"font-size:15px;line-height:1.65;color:#334155;\">\n                    <p style=\"margin:0 0 14px 0;\">Use the code below to verify your identity. It expires shortly.</p><p style=\"margin:0;font-size:28px;letter-spacing:0.12em;font-weight:800;color:#0a4a29;\">{{ .Token }}</p>\n                  </div>\n                </div>\n              </td>\n            </tr>\n            <tr>\n              <td style=\"paddi